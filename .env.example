# ==============================================================================
# Lodestar Environment Configuration (Sample)
# ==============================================================================
# INSTRUCTIONS: 
# 1. Copy this file and rename it to exactly: .env
# 2. Replace the placeholder values below with your actual database credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE CONNECTION
# ------------------------------------------------------------------------------
# The connection string to your Bitmagnet PostgreSQL database.
# Format: postgresql://[username]:[password]@[host]:[port]/[database_name]

# -> IF RUNNING VIA DOCKER COMPOSE (Recommended):
# Use the exact name of your database container as the host (usually 'postgres').
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/bitmagnet"

# -> IF RUNNING MANUALLY (Node.js without Docker):
# Use 'localhost' or the IP address of your Unraid/Linux server.
POSTGRES_DB_URL="postgres://bitmagnet:YOUR_PASSWORD@localhost:5432/bitmagnet"